# Sehat-Saathi Environment Variables
# Copy this file to .env and fill in the values.

# --- Backend ---
# Your Google Gemini API key (get it from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Port for the backend server (default: 3000)
PORT=3000

# --- Frontend (Vite) ---
# URL of the backend API server.
# In development this defaults to http://localhost:3000.
# Set to your deployed backend URL for production (e.g. on Render or Railway).
VITE_API_URL=http://localhost:3000
